# =========================
# LLM provider selection
# Supported: openai / qwen / anthropic
# =========================
LLM_PROVIDER=qwen
LLM_MODEL=qwen-plus

# =========================
# Qwen / DashScope (OpenAI-compatible)
# Used when LLM_PROVIDER=qwen
# =========================
QWEN_MODEL=qwen-plus
QWEN_API_KEY=your-dashscope-key
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_ENABLE_THINKING=false

# =========================
# OpenAI or OpenAI-compatible endpoint
# Used when LLM_PROVIDER=openai
# OPENAI_BASE_URL can be left empty for the official OpenAI endpoint
# =========================
OPENAI_API_KEY=your-openai-or-compatible-key
OPENAI_BASE_URL=

# =========================
# Anthropic
# Used when LLM_PROVIDER=anthropic
# ANTHROPIC_BASE_URL can be left empty for the official Anthropic endpoint
# =========================
ANTHROPIC_API_KEY=your-anthropic-key
ANTHROPIC_BASE_URL=
ANTHROPIC_MODEL=

# =========================
# MySQL drug knowledge base
# If disabled or unavailable, MedAgent automatically falls back
# to the built-in drug knowledge base in code.
# =========================
MYSQL_DRUG_DB_ENABLED=true

# Preferred: explicit MySQL URL
# MYSQL_URL=mysql+pymysql://root:your-mysql-password@127.0.0.1:3306/drug_db?charset=utf8mb4

# Or configure by discrete fields
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your-mysql-password
MYSQL_DATABASE=drug_db
MYSQL_CHARSET=utf8mb4
MYSQL_POOL_RECYCLE=1800
